# Add these in Cursor Dashboard → Cloud Agents → Secrets (NOT in git).
# See .cursor/skills/ado-universal-pr-review/reference/cloud-mcp-setup.md

# Azure DevOps MCP (@azure-devops/mcp --authentication pat)
# Value = base64 of "cursor-bot:YOUR_RAW_ADO_PAT"
# Generate: echo -n "cursor-bot:YOUR_RAW_ADO_PAT" | base64
PERSONAL_ACCESS_TOKEN=

# Optional: default project hint (also set in .cursor/mcp.json user-ado env)
# ado_mcp_project=Traffix Medallion
